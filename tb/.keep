module lab4_0tb;
    parameter SIZE = 8;
    logic [SIZE-1:0] a, b, s;
    logic overflow;
    logic [SIZE-1:0] expected_s;
    logic expected_overflow;
    int errors, total_tests;

    lab4_0 #(.SIZE(SIZE)) dut (
        .a(a),
        .b(b),
        .s(s),
        .overflow(overflow)
    );

    typedef struct {
        logic [SIZE-1:0] a;
        logic [SIZE-1:0] b;
        logic [SIZE-1:0] exp_s;
        logic exp_ov;
        string description;
    } test_vector_t;

    const test_vector_t tests[] = '{
        '{8'b00000011, 8'b00000001, 8'b00000100, 1'b0, "+3 + +1 = +4"},
        '{8'b10000011, 8'b10000001, 8'b10000100, 1'b0, "-3 + -1 = -4"},
        '{8'b00000101, 8'b00000010, 8'b00000111, 1'b0, "+5 + +2 = +7"},
        '{8'b10000101, 8'b10000010, 8'b10000111, 1'b0, "-5 + -2 = -7"},
        
        '{8'b01111111, 8'b00000001, 8'b10000000, 1'b1, "+127 + +1 = переполнение"},
        '{8'b11111111, 8'b10000001, 8'b10000000, 1'b1, "-127 + -1 = переполнение"},
        '{8'b01111111, 8'b01111111, 8'b11111110, 1'b1, "+127 + +127 = переполнение"},
        
        '{8'b00000101, 8'b10000010, 8'b00000011, 1'b0, "+5 + -2 = +3"},
        '{8'b00001111, 8'b10000101, 8'b00001010, 1'b0, "+15 + -5 = +10"},
        '{8'b00010010, 8'b10001010, 8'b00001000, 1'b0, "+18 + -10 = +8"},
        
        '{8'b00000011, 8'b10000110, 8'b10000011, 1'b0, "+3 + -6 = -3"},
        '{8'b00000101, 8'b10001111, 8'b10001010, 1'b0, "+5 + -15 = -10"},
        '{8'b00001010, 8'b10010010, 8'b10001000, 1'b0, "+10 + -18 = -8"},
        
        '{8'b00000101, 8'b10000101, 8'b00000000, 1'b0, "+5 + -5 = +0"},
        '{8'b00000000, 8'b10000000, 8'b00000000, 1'b0, "+0 + -0 = +0"},
        '{8'b01111111, 8'b11111111, 8'b00000000, 1'b0, "+127 + -127 = +0"},
        
        '{8'b01111111, 8'b00000000, 8'b01111111, 1'b0, "+127 + +0 = +127"},
        '{8'b11111111, 8'b00000000, 8'b11111111, 1'b0, "-127 + +0 = -127"},
        '{8'b00000000, 8'b00000000, 8'b00000000, 1'b0, "+0 + +0 = +0"},
        '{8'b10000000, 8'b10000000, 8'b00000000, 1'b0, "-0 + -0 = +0"},
        
        '{8'b00110010, 8'b00010101, 8'b01000111, 1'b0, "+50 + +21 = +71"},
        '{8'b10110010, 8'b10010101, 8'b11000111, 1'b0, "-50 + -21 = -71"},
        '{8'b00110010, 8'b10010101, 8'b00011101, 1'b0, "+50 + -21 = +29"},
        '{8'b00010101, 8'b10110010, 8'b10011101, 1'b0, "+21 + -50 = -29"},
        '{8'b00111111, 8'b00111111, 8'b01111110, 1'b0, "+63 + +63 = +126"},
        '{8'b00111111, 8'b01000000, 8'b01111111, 1'b0, "+63 + +64 = +127"},
        '{8'b01000000, 8'b01000000, 8'b10000000, 1'b1, "+64 + +64 = переполнение"}
    };

    function string num_to_string(logic [SIZE-1:0] num);
        string s;
        int value;
        
        if (num[SIZE-1] == 1'b0)
            value = num[SIZE-2:0];
        else
            value = -int'(num[SIZE-2:0]);
            
        s = $sformatf("%0d", value);
        return s;
    endfunction

    function string bin_with_spaces(logic [SIZE-1:0] num);
        string s = "";
        for (int i = SIZE-1; i >= 0; i--) begin
            s = {s, $sformatf("%1b", num[i])};
            if (i == SIZE-1) s = {s, " "};
            if (i == 4) s = {s, " "};
        end
        return s;
    endfunction

    initial begin
        errors = 0;
        total_tests = tests.size();
        
        $display("==========================================================");
        $display("STARTING 8-BIT SIGN-MAGNITUDE ADDER TESTBENCH");
        $display("Size: %0d bits", SIZE);
        $display("Number range: from %0d to %0d", -(1<<(SIZE-1))+1, (1<<(SIZE-1))-1);
        $display("Number of tests: %0d", total_tests);
        $display("==========================================================\n");

        for (int i = 0; i < total_tests; i++) begin
            a = tests[i].a;
            b = tests[i].b;
            expected_s = tests[i].exp_s;
            expected_overflow = tests[i].exp_ov;
            
            $display("Test %0d: %s", i+1, tests[i].description);
            $display(" a = %s (%s)", bin_with_spaces(a), num_to_string(a));
            $display(" b = %s (%s)", bin_with_spaces(b), num_to_string(b));
            
            #10;
            
            $display("Expected: s = %s (%s), overflow = %b", 
                     bin_with_spaces(expected_s), num_to_string(expected_s), expected_overflow);
            $display("  Got:      s = %s (%s), overflow = %b", 
                     bin_with_spaces(s), num_to_string(s), overflow);
            
            if (tests[i].exp_ov) begin
                if (overflow !== 1'b1) begin
                    $display("ERROR: Overflow flag not set!");
                    errors++;
                end else begin
                    $display("OK (overflow detected)");
                end
            end else begin
                if (s !== expected_s || overflow !== 1'b0) begin
                    $display("ERROR: Mismatch!");
                    if (s !== expected_s)
                        $display("       s: expected %s, got %s", 
                                 bin_with_spaces(expected_s), bin_with_spaces(s));
                    if (overflow !== 1'b0)
                        $display("       overflow: expected 0, got %b", overflow);
                    errors++;
                end else begin
                    $display("OK");
                end
            end
            $display("----------------------------------------------------------\n");
        end

        $display("==========================================================");
        $display("TESTBENCH FINISHED");
        $display("Total tests: %0d", total_tests);
        $display("Errors:      %0d", errors);
        if (errors == 0)
            $display("STATUS: ALL TESTS PASSED");
        else
            $display("STATUS: %0d TEST(S) FAILED", errors);
        $display("==========================================================");
        
        $finish;
    end

    always @(a or b or s or overflow) begin
        $display("[%0t ns] a=%s b=%s -> s=%s overflow=%b", 
                 $time, bin_with_spaces(a), bin_with_spaces(b), 
                 bin_with_spaces(s), overflow);
    end

endmodule
